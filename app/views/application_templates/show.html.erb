<h1>
  Application #<%= @the_application.id %> details
</h1>

<article>
  <div>
    <a href="/applications">
      Go back
    </a>
  </div>

  <% if user_signed_in? && current_user.id == @the_application.user_id %>
    <div>
      <a href="/delete_application/<%= @the_application.id %>">
        Withdraw application
      </a>
    </div>
  <% end %>

  <dl>
    <dt>
      Listing
    </dt>
    <dd>
      <a href="/listings/<%= @the_application.listing_id %>">
        Listing #<%= @the_application.listing_id %>
      </a>
    </dd>

    <dt>
      Applicant
    </dt>
    <dd>
      <% if @the_application.user.present? %>
        <%= @the_application.user.email %>
      <% else %>
        <%= @the_application.user_id %>
      <% end %>
    </dd>

    <dt>
      Message to owner
    </dt>
    <dd>
      <%= @the_application.message_to_owner %>
    </dd>

    <dt>
      Priority rank
    </dt>
    <dd>
      <%= @the_application.priority_rank %>
    </dd>

    <dt>
      Status
    </dt>
    <dd>
      <%= @the_application.status %>
    </dd>

    <dt>
      Decision notes
    </dt>
    <dd>
      <%= @the_application.decision_notes %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_application.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_application.updated_at) %> ago
    </dd>
  </dl>
</article>

<% if user_signed_in? && current_user.id == @the_application.listing.owner_id %>
  <hr>

  <article>
    <header>
      <h2>
        Owner decision
      </h2>
    </header>

    <form action="/modify_application/<%= @the_application.id %>" method="post">
      <div>
        <label for="priority_rank_box">
          Priority rank
        </label>

        <input type="text" id="priority_rank_box" name="query_priority_rank" value="<%= @the_application.priority_rank %>">
      </div>

      <div>
        <label for="status_box">
          Status
        </label>

        <input type="text" id="status_box" name="query_status" value="<%= @the_application.status %>">
      </div>

      <div>
        <label for="decision_notes_box">
          Decision notes
        </label>

        <input type="text" id="decision_notes_box" name="query_decision_notes" value="<%= @the_application.decision_notes %>">
      </div>

      <button type="submit">
        Update decision
      </button>
    </form>
  </article>
<% end %>

<hr>

<article>
  <header>
    <h2>
      Messages
    </h2>
  </header>

  <% if @messages.present? && @messages.any? %>
    <% @messages.each do |a_message| %>
      <div style="margin-bottom: 12px; padding: 10px; border: 1px solid #ddd; border-radius: 10px;">
        <div style="font-size: 14px; margin-bottom: 6px;">
          <strong>
            <% if a_message.sender_id == current_user.id %>
              You
            <% else %>
              <% if a_message.sender.present? %>
                <%= a_message.sender.email %>
              <% else %>
                User #<%= a_message.sender_id %>
              <% end %>
            <% end %>
          </strong>

          <span style="color:#666;">
            · <%= time_ago_in_words(a_message.created_at) %> ago
          </span>
        </div>

        <div>
          <%= simple_format(a_message.body) %>
        </div>

        <% if a_message.sender_id == current_user.id %>
          <div style="margin-top: 6px;">
            <a href="/delete_message/<%= a_message.id %>">
              Delete
            </a>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p>
      No messages yet.
    </p>
  <% end %>

  <hr>

  <h3>
    Send a message
  </h3>

  <form action="/insert_message" method="post">
    <div>
      <label for="body_box">
        Message
      </label>

      <input
        type="text"
        id="body_box"
        name="query_body"
        placeholder="Type your message..."
      >
    </div>

    <input type="hidden" name="query_application_id" value="<%= @the_application.id %>">

    <button type="submit">
      Send
    </button>
  </form>
</article>
