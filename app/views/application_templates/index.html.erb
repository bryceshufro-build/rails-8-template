<h1>
  Applications
</h1>

<hr>

<% if user_signed_in? %>

  <article>
    <header>
      <h2>
        Applications to my listings
      </h2>
    </header>

    <% if @applications_to_my_listings.present? && @applications_to_my_listings.any? %>
      <ul>
        <% @applications_to_my_listings.each do |an_application| %>
          <li>
            <a href="/applications/<%= an_application.id %>">
              <% if an_application.user.present? %>
                <%= an_application.user.email %>
              <% else %>
                Applicant #<%= an_application.user_id %>
              <% end %>
            </a>
            — Listing #<%= an_application.listing_id %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>
        No applications yet.
      </p>
    <% end %>
  </article>

  <hr>

  <article>
    <header>
      <h2>
        My applications
      </h2>
    </header>

    <% if @my_applications.present? && @my_applications.any? %>
      <ul>
        <% @my_applications.each do |an_application| %>
          <li>
            <a href="/applications/<%= an_application.id %>">
              Listing #<%= an_application.listing_id %>
            </a>
            — <%= an_application.status.presence || "submitted" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>
        You have not submitted any applications.
      </p>
    <% end %>
  </article>

<% else %>

  <p>
    Please sign in to view applications.
  </p>

<% end %>

<hr>
