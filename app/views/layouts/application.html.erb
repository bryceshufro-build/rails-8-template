<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails 8 Template" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="page-shell nav-row">
        <div class="brand">
          <a href="/">Apartment Pass-Down</a>
        </div>

        <nav class="main-nav">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="/listings/new">New listing</a>
          <a href="/applications">Applications</a>
          <a href="/profile">Profile</a>
        </nav>

        <div class="auth-area">
          <% if user_signed_in? %>
            <span class="signed-in-text">
              <%= current_user.email %>
            </span>

            <%= button_to "Sign out",
                destroy_user_session_path,
                method: :delete,
                form: { style: "display:inline;" },
                class: "secondary-button" %>
          <% else %>
            <a class="nav-pill" href="/users/sign_in">Sign in</a>
            <a class="nav-pill nav-pill-primary" href="/users/sign_up">Sign up</a>
          <% end %>
        </div>
      </div>
    </header>

    <main class="page-shell page-content">
      <% if notice.present? %>
        <div class="flash flash-notice">
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="flash flash-alert">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
