<h1>
  Listings
</h1>

<hr>

<% if user_signed_in? %>
  <article>
    <header>
      <h2>
        My listings
      </h2>
    </header>

    <% if @my_listings.any? %>
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px;">
        <% @my_listings.each do |a_listing| %>
          <a href="/listings/<%= a_listing.id %>" style="text-decoration:none; color:inherit;">
            <article style="margin-bottom:0; height:100%;">
              <% if a_listing.photos.attached? %>
                <div style="margin-bottom:12px;">
                  <%= image_tag(a_listing.photos.first, style: "width:100%; height:220px; object-fit:cover; border-radius:12px; display:block;") %>
                </div>
              <% end %>

              <h3 style="margin-bottom:6px;">
                <%= a_listing.title.presence || "Listing ##{a_listing.id}" %>
              </h3>

              <p style="margin-bottom:6px; color:#5b6773;">
                <%= a_listing.neighborhood %>
              </p>

              <p style="margin-bottom:6px;">
                $<%= a_listing.monthly_rent %> / month
              </p>

              <p style="margin-bottom:0; color:#5b6773;">
                <%= a_listing.bedrooms %> bd · <%= a_listing.bathrooms %> ba
              </p>
            </article>
          </a>
        <% end %>
      </div>
    <% else %>
      <p>
        You have not posted any listings yet.
      </p>
    <% end %>
  </article>

  <hr>
<% end %>

<article>
  <header>
    <h2>
      The market
    </h2>
  </header>

  <% if @market_listings.any? %>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px;">
      <% @market_listings.each do |a_listing| %>
        <a href="/listings/<%= a_listing.id %>" style="text-decoration:none; color:inherit;">
          <article style="margin-bottom:0; height:100%;">
            <% if a_listing.photos.attached? %>
              <div style="margin-bottom:12px;">
                <%= image_tag(a_listing.photos.first, style: "width:100%; height:220px; object-fit:cover; border-radius:12px; display:block;") %>
              </div>
            <% end %>

            <h3 style="margin-bottom:6px;">
              <%= a_listing.title.presence || "Listing ##{a_listing.id}" %>
            </h3>

            <p style="margin-bottom:6px; color:#5b6773;">
              <%= a_listing.neighborhood %>
            </p>

            <p style="margin-bottom:6px;">
              $<%= a_listing.monthly_rent %> / month
            </p>

            <p style="margin-bottom:0; color:#5b6773;">
              <%= a_listing.bedrooms %> bd · <%= a_listing.bathrooms %> ba
            </p>
          </article>
        </a>
      <% end %>
    </div>
  <% else %>
    <p>
      No listings available right now.
    </p>
  <% end %>
</article>

<hr>
