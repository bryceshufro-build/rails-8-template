<h1>
  Listings
</h1>

<hr>

<% if user_signed_in? %>
  <article>
    <header>
      <h2>
        My listings
      </h2>
    </header>

    <% if @my_listings.any? %>
      <ul>
        <% @my_listings.each do |a_listing| %>
          <li>
            <a href="/listings/<%= a_listing.id %>">
              <%= a_listing.title.presence || "Listing ##{a_listing.id}" %>
            </a>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>
        You have not posted any listings yet.
      </p>
    <% end %>
  </article>

  <hr>
<% end %>

<article>
  <header>
    <h2>
      The market
    </h2>
  </header>

  <% if @market_listings.any? %>
    <ul>
      <% @market_listings.each do |a_listing| %>
        <li>
          <a href="/listings/<%= a_listing.id %>">
            <%= a_listing.title.presence || "Listing ##{a_listing.id}" %>
          </a>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>
      No listings available right now.
    </p>
  <% end %>
</article>

<hr>
